# Database
DATABASE_URL=sqlite:///data/database.db

# Feishu API (optional)
FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here
FEISHU_HOT_TOPICS_APP_TOKEN=your_app_token_here
FEISHU_HOT_TOPICS_TABLE_ID=your_table_id_here
FEISHU_CREATORS_APP_TOKEN=your_app_token_here
FEISHU_CREATORS_TABLE_ID=your_table_id_here

# Ima API (optional, Phase 2)
IMA_API_KEY=your_ima_api_key_here

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/mcn_ai.log

# WebSearch settings
MAX_CONCURRENT_SEARCHES=5
SEARCH_TIMEOUT=30
